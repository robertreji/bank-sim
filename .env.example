# ═══════════════════════════════════════════════════════════════
# bank-sim — Environment Variables Template
# Copy this file to .env and fill in real values.
# ═══════════════════════════════════════════════════════════════

# ── Server ──
PORT=3001

# ── Supabase (Bank Sim uses its own separate Supabase project) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-bank-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_URL=https://your-bank-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Anchor Integration ──
ANCHOR_WEBHOOK_URL=https://your-anchor-service.up.railway.app/api/anchor/webhook
ANCHOR_SERVICE_URL=https://your-anchor-service.up.railway.app

# ── Self-reference (for settle callbacks) ──
BANK_URL=https://your-bank-sim.vercel.app

# ── Service-to-Service Auth ──
# ⚠️ Replace these with strong random secrets for production!
# Generate with: openssl rand -base64 32
BANK_API_KEY=<strong-random-key>
ANCHOR_API_KEY=<strong-random-key>

# ╔══════════════════════════════════════════════════════════════╗
# ║ ⚠️  DO NOT set NODE_TLS_REJECT_UNAUTHORIZED=0 here!        ║
# ║ It disables TLS verification and is a MITM vulnerability.  ║
# ╚══════════════════════════════════════════════════════════════╝
